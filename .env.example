# Environment Variables — USA Data Map
#
# Copy this file to .env and fill in your real keys.
# NEVER commit the .env file itself — it is listed in .gitignore.
#
# Get your keys here:
#   Census API : https://api.census.gov/data/key_signup.html
#   FBI CDE    : https://api.data.gov/signup/

# ── Required for full data ──────────────────────────────
CENSUS_API_KEY=your_census_api_key_here
FBI_API_KEY=your_fbi_api_key_here

# ── Optional (not yet wired up) ─────────────────────────
NOAA_API_TOKEN=
FRED_API_KEY=
BLS_API_KEY=
BEA_API_KEY=
AIRNOW_API_KEY=
